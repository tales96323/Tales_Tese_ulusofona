# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Ambiente Virtual ──────────────────────────────────────────
.venv/
venv/
env/
.env/

# ── Distribution / Packaging ─────────────────────────────────
dist/
build/
*.egg-info/
*.egg
*.whl

# ── IDEs e Editores ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OS ────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store
._*

# ── Logs ──────────────────────────────────────────────────────
*.log

# ── Gemini / Antigravity (ferramenta de IA) ───────────────────
.gemini/
.agents/
