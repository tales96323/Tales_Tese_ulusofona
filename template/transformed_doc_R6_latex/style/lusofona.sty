% Pequenos atalhos semânticos.
%
% \code/\req: texto monoespaçado que PERMITE a quebra de linha em nomes
% longos de ficheiro, caminhos e comandos, garantindo a justificação do
% parágrafo no PDF (Anotacoes_R5, ponto 6). As oportunidades de quebra
% são introduzidas após "_" (via \_ redefinido, válido em todo o texto)
% e, dentro de \code, também após "/" e "." (re-tokenização com
% \scantokens, robusta em legendas e títulos).
\begingroup
  \catcode`\/=\active
  \catcode`\.=\active
  \gdef\@codedefbreaks{\def/{\char`\/\penalty0 }\def.{\char`\.\penalty0 }}%
\endgroup
\protected\def\@codescan#1{%
  \begingroup
    \endlinechar=-1
    \catcode`\/=\active
    \catcode`\.=\active
    \@codedefbreaks
    \scantokens{#1}%
  \endgroup
}
\renewcommand{\_}{\textunderscore\allowbreak}
% \texorpdfstring garante \emph{bookmarks} PDF limpos quando \code surge
% em títulos de secção (usa o texto simples na string PDF).
\newcommand{\code}[1]{\texorpdfstring{\texttt{\@codescan{#1}}}{#1}}
\newcommand{\req}[1]{\texttt{#1}}
\newcommand{\eg}{e.g.\@\xspace}
\newcommand{\ie}{i.e.\@\xspace}
\newcommand{\cf}{cf.\@\xspace}
\RequirePackage{xspace}

