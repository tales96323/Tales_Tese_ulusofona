% ============================================================================
%  lusofona.sty — Estilo visual aproximado do template oficial da
%  Universidade Lusófona (Mestrado em Engenharia Informática e Sistemas de
%  Informação). Concebido para o documento "ULusofona_template_Tese" R5.
%
%  Pretende ser compilável com pdflatex, xelatex ou lualatex. Recomenda-se
%  xelatex/lualatex (fontes do sistema + suporte Unicode nativo).
% ============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{lusofona}[2026/05/30 v1.0 Lusófona Thesis Style]

% --- Margens (próximas das do template Word: 3 cm esq./sup., 2,5 cm restantes)
\RequirePackage[a4paper,
    left=3cm, right=2.5cm,
    top=3cm, bottom=2.5cm,
    headheight=15pt]{geometry}

% --- Idioma e codificação --------------------------------------------------
\RequirePackage[main=portuguese,english]{babel}
\RequirePackage{csquotes}

% --- Tipografia ------------------------------------------------------------
\RequirePackage{microtype}
% Carrega fontes do sistema só se xelatex/lualatex; caso contrário, fallback Latin Modern.
\RequirePackage{iftex}
\ifPDFTeX
    \RequirePackage[T1]{fontenc}
    \RequirePackage[utf8]{inputenc}
    \RequirePackage{lmodern}
\else
    \RequirePackage{fontspec}
    \setmainfont{TeX Gyre Termes}        % equivalente livre a Times New Roman
    \setsansfont{TeX Gyre Heros}         % equivalente a Helvetica/Arial
    \setmonofont{TeX Gyre Cursor}        % monoespaçada
\fi

% --- Espaçamento e parágrafo (regra Lusófona: 1.5 entrelinhas, parágrafo com indent)
\RequirePackage{setspace}
\onehalfspacing
\setlength{\parskip}{4pt}
\setlength{\parindent}{1.25em}

% --- Cabeçalhos de capítulo (sóbrios, sans-serif, cor preta) ----------------
\RequirePackage{titlesec}
\titleformat{\chapter}[display]
    {\normalfont\sffamily\Huge\bfseries}
    {\chaptertitlename\ \thechapter}{20pt}{\Huge}
\titleformat*{\section}{\normalfont\sffamily\Large\bfseries}
\titleformat*{\subsection}{\normalfont\sffamily\large\bfseries}
\titleformat*{\subsubsection}{\normalfont\sffamily\normalsize\bfseries}
\titlespacing*{\chapter}{0pt}{0pt}{30pt}

% --- Cabeçalho e rodapé ----------------------------------------------------
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhead[L]{\nouppercase{\sffamily\small\leftmark}}
\fancyhead[R]{\sffamily\small\thepage}
\fancypagestyle{plain}{
    \fancyhf{}
    \renewcommand{\headrulewidth}{0pt}
    \fancyfoot[C]{\sffamily\small\thepage}
}

% --- Listas e tabelas ------------------------------------------------------
\RequirePackage{enumitem}
\setlist{itemsep=2pt, topsep=4pt}
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{tabularx}
\RequirePackage{longtable}
\RequirePackage{multirow}
\RequirePackage{makecell}

% --- Cores, figuras, hiperligações -----------------------------------------
\RequirePackage[table,dvipsnames]{xcolor}
\definecolor{LusofonaBlue}{HTML}{003366}     % azul institucional aproximado
\definecolor{LusofonaAccent}{HTML}{B22222}   % acento (capa)
\definecolor{CodeBg}{HTML}{F7F7F7}
\definecolor{NoteBg}{HTML}{EEF2F7}

\RequirePackage{graphicx}
\graphicspath{{figures/}{../../}{../}{./}}
\RequirePackage{caption}
\captionsetup{font=small, labelfont=bf, labelsep=endash}
\RequirePackage{subcaption}

\RequirePackage[hidelinks,
    colorlinks=true,
    linkcolor=LusofonaBlue,
    citecolor=LusofonaBlue,
    urlcolor=LusofonaBlue]{hyperref}

% --- Matemática ------------------------------------------------------------
\RequirePackage{amsmath, amssymb, amsthm, mathtools}
\RequirePackage{bm}

% cleveref deve ser carregado depois de amsmath e hyperref.
% O idioma é detetado automaticamente a partir do babel.
