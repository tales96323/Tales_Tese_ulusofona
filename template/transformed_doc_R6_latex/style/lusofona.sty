        {9}{{{\color{blue!60!black}9}}}{1}
        {:}{{{\color{red!60!black}{:}}}}{1}
        {,}{{{\color{red!60!black}{,}}}}{1}
        {\{}{{{\color{black}{\{}}}}{1}
