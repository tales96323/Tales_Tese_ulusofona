digraph RequirementGraph {
    rankdir=LR;
    node [shape=box, style=filled, fillcolor=lightyellow];
    "REQ_DECISION_TREE" -> "REQ_SKLEARN_TAGS";
    "REQ_FEATURE_UNION" -> "REQ_PIPELINE";
