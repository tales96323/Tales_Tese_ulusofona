    "REQ_PIPELINE" -> "REQ_SKLEARN_TAGS";
    "REQ_PIPELINE_FIT" -> "REQ_DECISION_TREE";
    "REQ_PIPELINE_FIT" -> "REQ_FEATURE_UNION";
    "REQ_PIPELINE_FIT" -> "REQ_LINEAR_MODEL";
    "REQ_PIPELINE_FIT" -> "REQ_LOGISTIC_REGRESSION";
    "REQ_PIPELINE_FIT" -> "REQ_PIPELINE";
    "REQ_PIPELINE_PREDICT" -> "REQ_DECISION_TREE";
    "REQ_PIPELINE_PREDICT" -> "REQ_FEATURE_UNION";
    "REQ_PIPELINE_PREDICT" -> "REQ_LINEAR_MODEL";
    "REQ_PIPELINE_PREDICT" -> "REQ_LOGISTIC_REGRESSION";
    "REQ_PIPELINE_PREDICT" -> "REQ_PIPELINE";
    "REQ_SKLEARN_TAGS" -> "REQ_PIPELINE";
}